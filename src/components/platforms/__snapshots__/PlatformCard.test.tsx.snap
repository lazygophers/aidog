                />
              </div>
              <div
                style="position: absolute; top: -3px; right: -3px; width: 10px; height: 10px; border-radius: 50%; background: var(--color-success, var(--color-success)); border: 2px solid var(--bg-primary); box-shadow: 0 0 4px var(--color-success, var(--color-success))60;"
              />
            </div>
            <div
              style="min-width: 0px; flex: 1 1 0%;"
            >
              <div
                style="font-weight: 600; font-size: 14px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
              >
                Test Platform
