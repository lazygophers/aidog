              style="position: relative; flex-shrink: 0;"
            >
              <div
                style="width: 36px; height: 36px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: transparent; border: 1px solid var(--accent)30; color: var(--accent); font-size: 12px; font-weight: 700; overflow: hidden;"
