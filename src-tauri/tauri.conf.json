{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AiDog",
  "version": "0.1.4",
  "identifier": "com.aidog.app",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx tsc && npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AiDog",
        "width": 1026,
        "height": 759,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lazygophers/aidog/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyMjQ0QTA3QzkxMzY2RUUKUldUdVpoUEpCMG9rTW9DekF0aytXYUcyaDM0cWV0cS9kbXlJdDh1S0JiMzByNmVxNTdmMzVpSXEK"
    }
  }
}
