{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mitm-ca",
  "description": "Capability for installing/uninstalling the MITM root CA into the OS trust store. Scope is tightly locked to the exact CA install/remove commands per OS — no arbitrary shell execution. Linux uses one named shell command `linux-shell-ca` covering both trust (`cp <pem> <dest> && update-ca-certificates`) and untrust (`rm -f <dest> && update-ca-certificates --fresh`); the `-c` arg validator is a union regex locking both forms.",
  "windows": ["main", "popover"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "macos-trust-ca",
          "command": "/usr/bin/security",
          "args": [
            "add-trusted-cert",
            "-d",
            "-r",
            "trustRoot",
            "-k",
            "/Library/Keychains/System.keychain",
            { "validator": "^/.+\\.pem$" }
          ]
        },
        {
          "name": "macos-remove-ca",
          "command": "/usr/bin/security",
          "args": [
            "delete-certificate",
            "-Z",
            { "validator": "^[0-9A-Fa-f]+$" }
          ]
        },
        {
          "name": "windows-trust-ca",
          "command": "certutil",
          "args": ["-addstore", "-f", "Root", { "validator": "^.+\\.pem$|^\\.+\\.crt$" }]
        },
        {
          "name": "windows-remove-ca",
          "command": "certutil",
          "args": ["-delstore", "Root", { "validator": "^[0-9A-Fa-f]+$" }]
        },
        {
          "name": "linux-shell-ca",
          "command": "/bin/sh",
          "args": [
            "-c",
            {
              "validator": "^cp /.+\\.pem /usr/local/share/ca-certificates/aidog-ca\\.crt && update-ca-certificates$|^rm -f /usr/local/share/ca-certificates/aidog-ca\\.crt && update-ca-certificates --fresh$"
            }
          ]
        }
      ]
    }
  ]
}
